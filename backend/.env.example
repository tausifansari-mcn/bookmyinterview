# ============================================================
# Book My Interview — Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

NODE_ENV=development
PORT=5055
FRONTEND_URL=http://localhost:5173

# ── MySQL Database (Remote) ──────────────────────────────────
DB_HOST=122.184.128.90
DB_PORT=3306
DB_USER=root       # ← fill your MySQL username
DB_PASSWORD=vicidialnow     # ← fill your MySQL password
DB_NAME=suggest
DB_POOL_MAX=20

# ── JWT Auth ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-64-char-random-hex-string-here-minimum-32-chars!!
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-hex-string-here!!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES=7d

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tausif.ansari@teammas.in       # ← your Gmail / SMTP username
SMTP_PASS=Sector@61           # ← App password (not Gmail password)
SMTP_FROM=tausif.ansari@teammas.in
SMTP_FROM_NAME=Book My Interview

# ── AI (Claude / Anthropic) ──────────────────────────────────
ANTHROPIC_API_KEY=   # ← get from console.anthropic.com
AI_MODEL=claude-sonnet-4-6

# ── Payments (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
