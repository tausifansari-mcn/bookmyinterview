# ── DATABASE ─────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=getjob

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=bmi-super-secret-jwt-key-change-this-2024!!

# ── EMAIL (SMTP / Gmail) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM=your_email@gmail.com

# ── SERVER ───────────────────────────────────────────────────
PORT=5055
NODE_ENV=development

# ── AI / CLAUDE (optional) ───────────────────────────────────
ANTHROPIC_API_KEY=your_claude_api_key_here

# ── FILE UPLOADS ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
